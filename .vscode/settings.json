{
  // Map .mjs files to JavaScript so Prettier can format them
  "files.associations": {
    "*.mjs": "javascript"
  },

  // Use Prettier as the default formatter for TypeScript files
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },

  // Run ESLint fix on save as well
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },

  // ESLint validation for TS files
  "eslint.validate": ["typescript", "javascript"],

  // Disable the built-in TS formatter so it doesn't fight with Prettier
  "typescript.preferences.quoteStyle": "single",
  "typescript.format.enable": false,

  // Force LF line endings to match Prettier "endOfLine": "lf"
  "files.eol": "\n"
}
